#include <stdio.h>
#include <math.h>

int main() {
    float P, R, T, SI, CI;

    printf("Enter Principal, Rate, Time: ");
    scanf("%f %f %f", &P, &R, &T);

    SI = (P * R * T) / 100;
    CI = P * pow((1 + R/100), T) - P;

    printf("Simple Interest = %.2f\n", SI);
    printf("Compound Interest = %.2f\n", CI);

    return 0;
}
